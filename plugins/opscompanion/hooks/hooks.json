{
  "description": "OpsCompanion hooks — load context on session start, auto-approve opc CLI calls",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "opc context --full-memory"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/auto-approve-opc.js"
          }
        ]
      }
    ]
  }
}
